# --- API keys (Actions secrets) ---
GEMINI_API_KEY=            # Veo video gen + Gemini lyrics/judge + character sheets
ELEVENLABS_API_KEY=        # Music API (songs) + TTS (learning narration) — paid plan required for commercial use
KIE_API_KEY=               # optional: Seedance fallback / cheap smoke tests

# --- YouTube (Actions secrets; see scripts/youtube_oauth_bootstrap.py) ---
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=          # consent screen must be "In production" or this dies in 7 days

# --- Phase 2: Meta (Actions secrets) ---
IG_USER_ID=
IG_ACCESS_TOKEN=
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
GH_PAT=                    # repo-scoped PAT for the token-refresh workflow

# --- Tunables (Actions repo variables) ---
VIDEO_BACKEND=veo          # veo | seedance
VEO_MODEL=veo-3.1-fast-generate-preview
VEO_RESOLUTION=1080p       # falls back to 720p automatically if rejected for 9:16
VEO_USD_PER_SECOND=0.15
KIE_SEEDANCE_MODEL=bytedance/seedance-2-mini
KIE_RESOLUTION=480p        # smoke-test tier
KIE_USD_PER_SECOND=0.02    # set from your actual credit pack pricing
SCENE_SECONDS=24           # must be a multiple of CLIP_SECONDS; 3 clips/scene
CLIP_SECONDS=8
SCENES_PER_SHORT=2         # 2x24s + 4s outro = ~52s short
MAX_USD_PER_RUN=12
MAX_USD_PER_MONTH=200
MAX_CLIP_ATTEMPTS=5        # content-filter retry ladder depth
SERIES_ID=pip-and-lulu
CHANNEL_HANDLE=            # e.g. @PipAndLulu
LYRICS_MODEL=gemini-2.5-flash
THEME=                     # force a theme for one run (else random unposted)
